<style>
  html, body {
    height: auto;
    min-height: 100vh;
    overflow-y: auto;
    margin: 0;
    padding: 0;
    background-color: #000;
    color: #fff;
  }

  .welcome-box {
    padding: 3rem 1rem;
    max-width: 800px;
    margin: 0 auto;
    height: auto;
    overflow: visible;
  }

  .homepage-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .homepage-title .highlight {
    color: #ffd700;
  }

  .lead {
    color: #ccc;
    margin-bottom: 2rem;
  }

  .form-container {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .form-group-wrapper {
    margin-bottom: 1.5rem;
    overflow: visible;
  }

  .form-label {
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: #ffffff;
    display: block;
  }

  .form-control, .form-select {
    width: 100%;
    background-color: #1a1a1a;
    border: 1px solid #333;
    color: #fff;
    padding: 0.5rem;
    overflow: visible;
  }

  .form-control::placeholder {
    color: #808080;
  }

  .form-control:focus, .form-select:focus {
    background-color: #222;
    border-color: #ffd700;
    box-shadow: 0 0 0 0.25rem rgba(255, 215, 0, 0.15);
    color: #fff;
  }

  .form-select option {
    background-color: #1a1a1a;
    color: #fff;
  }

  .btn-get-started {
    background-color: #fff;
    color: #000;
    border: 2px solid #fff;
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .btn-get-started:hover {
    background-color: #ffd700;
    border-color: #ffd700;
    color: #000;
  }

   .btn-choose {
    background-color: #fff;
    color: #000;
    border: 1px solid #fff;
    font-weight: 200;
    padding: 1rem 1rem;
    font-size: 1rem;
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;
  }

  .alert-danger {
    background-color: #2a1a1a;
    border: 1px solid #664444;
    color: #ff9999;
  }

  #engineeringFields {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  #engineeringFields.show {
    max-height: 1000px;
  }

  #mathFields {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  #mathFields.show {
    max-height: 1000px;
  }

  #enterCourses {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  #enterCourses.show {
    max-height: 1000px;
  }

  #uploadFile {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  #uploadFile.show {
    max-height: 1000px;
  }

</style>
</head>
<body>

<div class="welcome-box">
  <h1 class="homepage-title">
    Welcome to <span class="highlight">OnTrack</span>
  </h1>
  <p class="lead">
    Plan your academic journey with ease. Make sure you're on track to graduate on time.
  </p>

  <!-- Error alert placeholder (if using server-side rendering) -->
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <strong>Error:</strong> <%= error %>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <!-- === Form === -->
  <form action="/submit" method="POST" enctype="multipart/form-data" class="form-container">
    <!-- Major Selection -->
    <div class="form-group-wrapper">
      <label for="major" class="form-label">Select Your Major:</label>
      <select class="form-select" id="major" name="major" required>
        <option value="">-- Choose a program --</option>
        <option value="BCS Computer Science">BCS Computer Science</option>
        <option value="BMath Computer Science">BMath Computer Science</option>
        <option value="BCFM Computing and Financial Management">BCFM Computing and Financial Management</option>
        <option value="BCS Data Science">BCS Data Science</option>
        <option value="Engineering">Engineering</option>
      </select>
    </div>

    <!-- Engineering Fields (hidden by default) -->
    <div id="engineeringFields">
      <div class="form-group-wrapper">
        <label for="engineeringMajor" class="form-label">Select Your Engineering Course:</label>
        <select class="form-select" id="engineeringMajor" name="engineeringMajor">
          <option value="">-- Choose a program --</option>
          <option value="Software Engineering">Software Engineering</option>
          <option value="Systems Design Engineering">Systems Design Engineering</option>
        </select>
      </div>
    </div>

      <div class="form-group-wrapper">
        <label class="form-label">Enter Your Most Recent Term:</label>
        <textarea class="form-control" name="term" rows="2" placeholder="Example: 1A, 1B, 2A"></textarea>
      </div>

    <div id="buttonGroup" style="text-align: center; margin-top: 1rem; margin-bottom: 1rem; margin: 1rem;">
      <button type="button" class="btn-choose fw-bold">Upload Transcript</button>
      <button type="button" class="btn-choose fw-bold">Manually Type in Courses</button>
    </div>

    <div id="enterCourses" class="form-group-wrapper">
      <label for="courses" class="form-label">Enter Your Courses:</label>
      <textarea class="form-control" id="courses" name="courses" rows="4" placeholder="Enter comma-separated courses"></textarea>
    </div>

    <div id="uploadFile" class="form-group-wrapper">
      <label for="transcriptFile" class="form-label">Upload a File:</label>
      <input type="file" name="transcriptFile" id="transcriptFile">
    </div>

    <!-- Submit Button -->
    <div style="text-align: center; margin-top: 1rem;">
      <button type="submit" class="btn btn-lg btn-get-started fw-bold">Get Started</button>
    </div>

  </form>
</div>


<script>
  const majorSelect = document.getElementById("major");
  const engineeringFields = document.getElementById("engineeringFields");
  const mathFields = document.getElementById("mathFields");
  const coursesField = document.getElementById("courses");
  const uploadFileField = document.getElementById("uploadFile");
  const enterCoursesField = document.getElementById("enterCourses");
  const buttonGroup = document.getElementById("buttonGroup");

  majorSelect.addEventListener("change", function () {
    if (this.value === "Engineering") {
      engineeringFields.classList.add("show");
    } else {
      engineeringFields.classList.remove("show");
    }
  });

  buttonGroup.addEventListener("click", function (event) {
    if (event.target.textContent.includes("Manually")) {
      enterCoursesField.classList.add("show");
      uploadFileField.classList.remove("show");
      coursesField.required = true;
    } else if (event.target.textContent.includes("Upload")) {
      uploadFileField.classList.add("show");
      enterCoursesField.classList.remove("show");
      coursesField.required = false;
    }
  });




</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>